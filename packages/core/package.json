{
  "name": "schema-cast-core",
  "version": "1.2.0",
  "description": "Schema generation logic for schema-cast",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepack": "cp ../../README.md .",
    "postpack": "rm -f README.md"
  },
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.4.0",
    "ajv": "^8.20.0",
    "js-yaml": "^4.2.0",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/pluralize": "^0.0.33",
    "mongoose": "^8.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "zod": "^3.0.0"
  }
}
